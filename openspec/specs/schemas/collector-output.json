{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "collector-output.json",
  "title": "Collector Output",
  "description": "Collector 产出数据的 JSON Schema，覆盖 knowledge/raw/*.json",
  "type": "object",
  "required": ["collected_at", "source", "version", "items"],
  "properties": {
    "collected_at": {
      "type": "string",
      "description": "采集时间，ISO 8601 格式"
    },
    "source": {
      "type": "string",
      "description": "数据源类型，多个源用逗号分隔，如 github,rss"
    },
    "version": {
      "type": "string",
      "description": "数据格式版本"
    },
    "items": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/collectorItem"
      }
    }
  },
  "$defs": {
    "collectorItem": {
      "type": "object",
      "required": [
        "title", "url", "source", "popularity", "popularity_type",
        "author", "created_at", "updated_at", "language", "topics",
        "description", "readme", "summary", "collected_at"
      ],
      "properties": {
        "title": {
          "type": "string"
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "source": {
          "type": "string",
          "description": "条目来源，如 github-search, rss"
        },
        "popularity": {
          "type": "integer",
          "minimum": 0
        },
        "popularity_type": {
          "type": "string",
          "description": "流行度类型，如 total_stars, none"
        },
        "author": {
          "type": "string",
          "description": "作者/组织名"
        },
        "created_at": {
          "type": "string",
          "description": "创建时间，ISO 8601 格式"
        },
        "updated_at": {
          "type": "string",
          "description": "更新时间，ISO 8601 格式"
        },
        "language": {
          "type": "string",
          "description": "主要编程语言，N/A 表示未知"
        },
        "topics": {
          "type": "array",
          "items": { "type": "string" }
        },
        "description": {
          "type": "string",
          "default": ""
        },
        "readme": {
          "type": "string",
          "default": "",
          "description": "README 内容前 5000 字符"
        },
        "summary": {
          "type": "string",
          "default": "",
          "description": "摘要，Collector 阶段置空，由 Analyzer 填充"
        },
        "collected_at": {
          "type": "string",
          "description": "采集时间，ISO 8601 格式"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
